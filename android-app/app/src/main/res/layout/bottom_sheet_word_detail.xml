<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/background_card"
    android:padding="24dp">

    <!-- Header with close button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <!-- Close button -->
        <ImageView
            android:id="@+id/closeImageView"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_close"
            android:background="?android:attr/selectableItemBackground"
            android:padding="4dp"
            android:contentDescription="@string/cd_close" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Word title -->
    <TextView
        android:id="@+id/wordTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:fontFamily="@font/playfair_display_bold"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        android:gravity="center"
        tools:text="Vulnerable" />

    <!-- Difficulty badge -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/difficultyChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/lato_regular"
            android:textSize="14sp"
            android:textColor="@color/text_on_primary"
            app:chipCornerRadius="8dp"
            app:chipMinHeight="28dp"
            tools:text="Medium" />

    </LinearLayout>

    <!-- English Meaning -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/lato_regular"
            android:text="@string/word_english_meaning"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/englishMeaningTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/lato_regular"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:lineSpacingExtra="2dp"
            tools:text="Open to attack or harm; susceptible to physical or emotional injury." />

    </LinearLayout>

    <!-- Hinglish Explanation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/lato_regular"
            android:text="@string/word_hinglish_explanation"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/hinglishExplanationTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/lato_regular"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:lineSpacingExtra="2dp"
            tools:text="Jisko hurt karne aasaani se; koi bhi cheez jo easily damage ho sakti hai." />

    </LinearLayout>

    <!-- Example Sentence -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/lato_regular"
            android:text="@string/word_example_sentence"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/exampleSentenceTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/lato_regular"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:lineSpacingExtra="2dp"
            tools:text="In my younger and more vulnerable years, my father gave me some advice." />

    </LinearLayout>

    <!-- Original Context -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/lato_regular"
            android:text="@string/word_original_context"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/originalContextTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input_field"
            android:fontFamily="@font/lato_regular"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:lineSpacingExtra="2dp"
            android:padding="12dp"
            android:maxLines="3"
            android:ellipsize="end"
            tools:text="In my younger and more vulnerable years my father gave me some advice that I've been turning over in my mind ever since." />

    </LinearLayout>

    <!-- Save to Notes button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/saveNoteButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_rounded_button"
        android:fontFamily="@font/lato_regular"
        android:text="@string/word_save_to_notes"
        android:textColor="@color/text_on_primary"
        android:textSize="16sp"
        app:cornerRadius="12dp" />

</LinearLayout>
