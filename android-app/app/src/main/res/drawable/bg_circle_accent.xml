<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    
    <!-- Solid accent color background -->
    <solid android:color="@color/accent" />
    
    <!-- Optional subtle gradient for depth -->
    <gradient
        android:startColor="@color/accent_light"
        android:endColor="@color/accent"
        android:angle="45" />
    
    <!-- Optional stroke for definition -->
    <stroke
        android:width="1dp"
        android:color="@color/accent_dark" />
</shape>
