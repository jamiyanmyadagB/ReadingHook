<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F5"
    tools:context=".ui.reader.ReaderActivity">

    <!-- Main content container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="80dp">

        <!-- Top bar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#FFFFFF"
            android:elevation="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="8dp">

                <!-- Back arrow -->
                <ImageView
                    android:id="@+id/backImageView"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_back"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="4dp"
                    android:contentDescription="@string/cd_back"
                    android:tint="#4B2E2E" />

                <!-- Book title -->
                <TextView
                    android:id="@+id/bookTitleTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="16dp"
                    android:fontFamily="@font/playfair_display_bold"
                    android:textColor="#4B2E2E"
                    android:textSize="18sp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    tools:text="The Great Gatsby" />

                <!-- Difficulty badge -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/difficultyChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/lato_regular"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    app:chipCornerRadius="8dp"
                    app:chipMinHeight="24dp"
                    tools:text="Medium" />

                <!-- 3-dot menu -->
                <ImageView
                    android:id="@+id/menuImageView"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_more_vert"
                    android:background="?android:attr/selectableItemBackground"
                    android:padding="4dp"
                    android:contentDescription="@string/cd_menu"
                    android:tint="#4B2E2E" />

            </LinearLayout>

        </androidx.appcompat.widget.Toolbar>

        <!-- Page indicator -->
        <TextView
            android:id="@+id/pageIndicatorTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/lato_regular"
            android:textColor="#8D6E63"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Page 1 of 50" />

        <!-- Reading content area -->
        <ScrollView
            android:id="@+id/contentScrollView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="16dp"
            android:background="#FFFFFF"
            android:padding="24dp"
            app:layout_constraintTop_toBottomOf="@id/pageIndicatorTextView"
            app:layout_constraintBottom_toTopOf="@+id/toggleSwitch"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/contentTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lato_regular"
                android:textColor="#4B2E2E"
                android:textSize="16sp"
                android:lineSpacingExtra="4dp"
                android:justificationMode="inter_word"
                android:textIsSelectable="true"
                tools:text="In my younger and more vulnerable years my father gave me some advice that I've been turning over in my mind ever since. 'Whenever you feel like criticizing anyone,' he told me, 'just remember that all the people in this world haven't had the advantages that you've had.'" />

        </ScrollView>

        <!-- Original/Translated toggle -->
        <LinearLayout
            android:id="@+id/toggleSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="#FFFFFF"
            android:padding="8dp"
            app:layout_constraintBottom_toTopOf="@id/bottomNavigationLayout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/originalTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:fontFamily="@font/lato_regular"
                android:text="@string/reader_original"
                android:textColor="#8D6E63"
                android:textSize="14sp"
                android:background="?android:attr/selectableItemBackground"
                android:padding="8dp" />

            <View
                android:layout_width="1dp"
                android:layout_height="20dp"
                android:background="#D4A373" />

            <TextView
                android:id="@+id/translatedTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/lato_regular"
                android:text="@string/reader_translated"
                android:textColor="#4B2E2E"
                android:textSize="14sp"
                android:background="?android:attr/selectableItemBackground"
                android:padding="8dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom navigation -->
    <LinearLayout
        android:id="@+id/bottomNavigationLayout"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <!-- Previous arrow -->
        <ImageView
            android:id="@+id/previousImageView"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_chevron_left"
            android:background="@drawable/bg_circle_accent"
            android:padding="8dp"
            android:contentDescription="@string/cd_previous_page"
            android:tint="#FFFFFF" />

        <!-- Page number -->
        <TextView
            android:id="@+id/pageNumberTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/playfair_display_bold"
            android:textColor="#4B2E2E"
            android:textSize="18sp"
            android:gravity="center"
            tools:text="1" />

        <!-- Next arrow -->
        <ImageView
            android:id="@+id/nextImageView"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_chevron_right"
            android:background="@drawable/bg_circle_accent"
            android:padding="8dp"
            android:contentDescription="@string/cd_next_page"
            android:tint="#FFFFFF" />

    </LinearLayout>

    <!-- Save Note FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/saveNoteFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_note_add"
        android:contentDescription="@string/word_save_to_notes"
        app:tint="#FFFFFF"
        app:backgroundTint="#F7C8D0" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
