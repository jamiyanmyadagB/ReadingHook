<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary"
    tools:context=".ui.splash.SplashActivity">

    <!-- Top decorative arc background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_top_arc" />

    <!-- Center content container -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- Logo image -->
        <ImageView
            android:id="@+id/logoImageView"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginBottom="24dp"
            android:src="@drawable/ic_logo"
            android:contentDescription="@string/cd_logo" />

        <!-- App name with Playfair Display Bold -->
        <TextView
            android:id="@+id/appNameTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/playfair_display_bold"
            android:text="@string/app_name"
            android:textColor="@color/text_on_primary"
            android:textSize="36sp"
            android:letterSpacing="0.02"
            android:gravity="center" />

        <!-- Subtitle with gold accent -->
        <TextView
            android:id="@+id/subtitleTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="48dp"
            android:fontFamily="@font/lato_regular"
            android:text="MEMORY+"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:letterSpacing="0.04"
            android:gravity="center" />

        <!-- Tagline -->
        <TextView
            android:id="@+id/taglineTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="48dp"
            android:fontFamily="@font/lato_regular"
            android:text="@string/app_tagline"
            android:textColor="@color/text_on_primary"
            android:textSize="14sp"
            android:letterSpacing="0.01"
            android:gravity="center" />

        <!-- Loading dots container -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <View
                android:id="@+id/dot1"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_dot" />

            <View
                android:id="@+id/dot2"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_dot" />

            <View
                android:id="@+id/dot3"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_dot" />

        </LinearLayout>

    </LinearLayout>

    <!-- Version text at very bottom -->
    <TextView
        android:id="@+id/versionTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        android:fontFamily="@font/lato_regular"
        android:text="v1.0.0"
        android:textColor="@color/text_hint"
        android:textSize="12sp"
        android:alpha="0.6" />

</FrameLayout>
