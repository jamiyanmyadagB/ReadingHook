##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh
#       is not compatible with bash, you'll need to install a POSIX-compatible shell
#       and correct the shebang line.
#
#   (2) This script is generated from the Gradle template within the Gradle project.
#
#       You can find Gradle at https://github.com/gradle/gradle/.
#
##############################################################################

# Attempt to set APP_HOME

# Resolve links: $0 may be a link
APP_PATH="$0"

# Need this for daisy-chained symlinks
while [ -h "$APP_PATH" ] ; do
    ls=`ls -ld "$APP_PATH"`
    link=`expr "$ls" : '.*-> \(.*\)$' \| cut -d= -f2`
    if expr "$link" : '.*' > /dev/null; then
        APP_PATH=`expr "$ls" : '.*-> \(.*\)$' \| cut -d= -f2`
    fi
done

# This is normally unused
# shellcheck disable=SC2034
APP_BASE_NAME=`basename "$APP_PATH"`
APP_HOME=$(dirname "$APP_PATH")

# Use cygpath if available
CYGPATH_EXE="cygpath"
if command -v $CYGPATH_EXE > /dev/null; then
    # shellcheck disable=SC2034
    APP_HOME=`$CYGPATH_EXE --unix --windows "$APP_HOME"`
fi

# Code from Ivy script contrib
# https://github.com/ivy/ivy/blob/master/src/example/scripts/ivyvar.sh
# shellcheck disable=SC2154
find_java_home() {
    if [ -n "$JAVA_HOME" ]; then
        if [ -x "$JAVA_HOME/jre/sh/java" ]; then
            # IBM's JDK on AIX uses strange locations for the executables
            JAVACMD="$JAVA_HOME/jre/sh/java"
        else
            JAVACMD="$JAVA_HOME/bin/java"
        fi
    else
        JAVACMD=`which java`
    fi
}

# Determine the Java command to use to start the JVM.
if [ -z "$JAVACMD" ] ; then
    JAVACMD="java"
fi

# For Cygwin, ensure paths are in UNIX format before anything is touched
if [ "$OSCYGWIN" = "true" ] ; then
    [ -n "$JAVA_HOME" ] &&
        JAVA_HOME=`cygpath --unix "$JAVA_HOME"`
    [ -n "$APP_HOME" ] &&
        APP_HOME=`cygpath --unix "$APP_HOME"`
fi

# For Darwin, add tools to PATH
if [ "$OS" = "Darwin" ]; then
    export PATH="$PATH:$APP_HOME/Contents/gradle-8.2/bin"
fi

# For Mingw, ensure paths are in UNIX format before anything is touched
if [ "$OS" = "Windows_NT" ] ; then
    [ -n "$JAVA_HOME" ] &&
        JAVA_HOME=`(cd "$JAVA_HOME" && pwd)`
    [ -n "$APP_HOME" ] &&
        APP_HOME=`(cd "$APP_HOME" && pwd)`
fi

# Escape application args
save () {
    for i do printf %s\\n "$i" | sed "s/ /\\\\ /g"; done
}
APP_ARGS=$(save "$@")

# Collect all arguments for the java command, following the shell quoting and substitution rules
eval set -- "$APP_ARGS"

# We use the java command to find the java version
JAVA_EXE="java"
if [[ -n "$JAVA_HOME" ]] && [[ -x "$JAVA_HOME/bin/java" ]]; then
    JAVA_EXE="$JAVA_HOME/bin/java"
fi

exec "$JAVA_EXE" \
  -Dorg.gradle.appname="$APP_BASE_NAME" \
  -classpath "$APP_HOME/gradle/wrapper/gradle-wrapper.jar" \
  org.gradle.wrapper.GradleWrapperMain \
  "$@"
